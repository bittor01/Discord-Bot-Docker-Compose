# Discord Bot Token
DISCORD_TOKEN=your_bot_token_here

# The ID of the voice channel that users join to create a new one
HUB_CHANNEL_ID=your_hub_channel_id_here

# The ID of the category where new voice channels will be created
CATEGORY_ID=your_category_id_here

# Path to the SQLite database file
DATABASE_PATH=./data/state.db

# Gamification Scaling
# XP awarded per second for active users
XP_PER_SECOND=1
# XP required for the first level (Level 1)
XP_LEVEL_BASE=900
# Percentage increase in XP required for each subsequent level (1.1 = 10% increase)
XP_LEVEL_RAMP=1.1

# XP Multipliers for different voice states (1.0 = 100%, 0.5 = 50%, etc.)
# When the user is muted but not deafened
XP_MULTIPLIER_MUTED=0.5
# When the user is deafened
XP_MULTIPLIER_DEAFENED=0.1

# Notification Settings
# Minimum minutes between level-up notifications to avoid spam
NOTIFICATION_COOLDOWN_MINUTES=15

# Static Voice Channels to monitor (comma-separated IDs)
# These are in addition to the dynamic channels managed by the bot
STATIC_CHANNELS=

# Cleanup Settings
# How many minutes a channel should stay empty before being deleted
EMPTY_CHANNEL_CLEANUP_DELAY_MINUTES=0
