# Discord Bot Token
DISCORD_TOKEN=your_bot_token_here

# Channels & Categories
HUB_CHANNEL_ID=your_hub_channel_id_here
CATEGORY_ID=your_category_id_here
BOT_OUTPUT_CHANNEL_ID=your_bot_output_channel_id_here

# Database
DATABASE_PATH=./data/state.db

# Gamification Configuration
XP_PER_SECOND=1
XP_LEVEL_BASE=900
XP_LEVEL_RAMP=1.1

# XP Multipliers
XP_MULTIPLIER_MUTED=0.5
XP_MULTIPLIER_DEAFENED=0.1
XP_MULTIPLIER_SCREENSHARE=1.5
# Group bonus: Each additional person adds a multiplier (e.g., 0.5 for 2nd person, 0.25 for 3rd)
# The second person provides 0.5x bonus to the group, etc.
XP_GROUP_BONUS_STEP=0.5

# Acclimation Settings
ACCLIMATION_TIME_MINUTES=15
ACCLIMATION_GRACE_PERIOD_MINUTES=7.5

# Notification Settings
NOTIFICATION_COOLDOWN_MINUTES=15

# Static Voice Channels to monitor (comma-separated IDs)
STATIC_CHANNELS=

# Cleanup Settings
EMPTY_CHANNEL_CLEANUP_DELAY_MINUTES=0

# Admin & Permissions
# Role ID required to use admin slash commands like /givexp
ADMIN_ROLE_ID=your_admin_role_id_here
# Hard limit for manual XP granting
MAX_MANUAL_XP_GRANT=10000

# Rate Limiting
# Maximum Discord API calls per second (Global)
MAX_API_CALLS_PER_SECOND=25

# Resets
# Day of week for weekly reset (0-6, 0=Sunday)
WEEKLY_RESET_DAY=0
# Day of month for monthly reset (1-31)
MONTHLY_RESET_DAY=1
