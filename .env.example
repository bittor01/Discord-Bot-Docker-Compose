# Discord Bot Token
DISCORD_TOKEN=your_bot_token_here

# Channels & Categories
HUB_CHANNEL_ID=your_hub_channel_id_here
CATEGORY_ID=your_category_id_here
BOT_OUTPUT_CHANNEL_ID=your_bot_output_channel_id_here

# Database
DATABASE_PATH=./data/state.db

# Gamification Configuration
XP_PER_SECOND=1
XP_LEVEL_BASE=900
XP_LEVEL_RAMP=1.1

# XP Multipliers
XP_MULTIPLIER_MUTED=0.5
XP_MULTIPLIER_DEAFENED=0.1
XP_MULTIPLIER_SCREENSHARE=1.5
XP_GROUP_BONUS_STEP=0.5

# Acclimation Settings
ACCLIMATION_TIME_MINUTES=15
ACCLIMATION_GRACE_PERIOD_MINUTES=7.5

# Leaderboard Settings
# Toggles: 1 to enable, 0 to disable
WEEKLY_LEADERBOARD_ENABLED=1
MONTHLY_LEADERBOARD_ENABLED=1
LIFETIME_LEADERBOARD_ENABLED=1

# Channel IDs for leaderboard posts (can be same or different)
WEEKLY_LEADERBOARD_CHANNEL_ID=your_weekly_channel_id_here
MONTHLY_LEADERBOARD_CHANNEL_ID=your_monthly_channel_id_here
LIFETIME_LEADERBOARD_CHANNEL_ID=your_lifetime_channel_id_here

# Resets
WEEKLY_RESET_DAY=0
MONTHLY_RESET_DAY=1

# Notification Settings
NOTIFICATION_COOLDOWN_MINUTES=15

# Static Voice Channels to monitor (comma-separated IDs)
STATIC_CHANNELS=

# Cleanup Settings
EMPTY_CHANNEL_CLEANUP_DELAY_MINUTES=0

# Admin & Permissions
ADMIN_ROLE_ID=your_admin_role_id_here
MAX_MANUAL_XP_GRANT=10000

# Rate Limiting
MAX_API_CALLS_PER_SECOND=25
